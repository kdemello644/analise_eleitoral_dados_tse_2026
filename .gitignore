# Python/cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
.env
.env.*

# Local/editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
.agents/
.git/

# Large electoral data, local databases and generated artifacts
dados/*
dados/**/
dados/**/*.parquet
dados/.gitkeep
*.parquet
*.zip
*.csv
*.jsonl
*.ndjson
*.pdf
*.sqlite
*.duckdb

# Pipeline outputs
resultados/
resultados*/
resultados_*/
resultados-*/
scripts/**/resultados*/

# Logs/reports generated by runs
logs/
*.log
*.tmp
*.bak

# Keep source code, manifests, docs and requirements versionable.
!README.md
!scripts/**/*.py
!scripts/**/*.md
!scripts/**/requirements.txt
